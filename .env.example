# ─────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────────
# DATABASE — Render PostgreSQL
# Use external URL locally; internal URL on Render
# ─────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# ─────────────────────────────────────────────────
# AUTH (custom JWT)
# ─────────────────────────────────────────────────
JWT_SECRET=generate_64_char_random_string
JWT_EXPIRY=7d
REFRESH_TOKEN_SECRET=generate_different_64_char_random_string
REFRESH_TOKEN_EXPIRY=30d
SA_JWT_SECRET=generate_superadmin_64_char_random_string
ALLOW_PUBLIC_SIGNUP=false

# ─────────────────────────────────────────────────
# AI — ANTHROPIC (Primary)
# ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=400
ANTHROPIC_TEMPERATURE=0.3
AI_CONFIDENCE_THRESHOLD=0.70

# Fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=400
OPENAI_TEMPERATURE=0.3
OPENAI_FALLBACK_ENABLED=true
AI_PRIMARY_PROVIDER=auto

# ─────────────────────────────────────────────────
# WHATSAPP — META CLOUD API
# ─────────────────────────────────────────────────
META_VERIFY_TOKEN=
META_APP_SECRET=
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_WABA_ID=

# ─────────────────────────────────────────────────
# FILES — CLOUDFLARE R2
# ─────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=propagent-files
R2_PUBLIC_URL=

# ─────────────────────────────────────────────────
# EMAIL — RESEND
# ─────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@propagent.in

# ─────────────────────────────────────────────────
# PAYMENTS
# ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────
# MIGRATIONS (set true once on first deploy)
# ─────────────────────────────────────────────────
RUN_MIGRATIONS=false
